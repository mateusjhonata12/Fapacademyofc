{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "password": { "type": "string" }
      },
      "required": ["id", "name", "email", "role"]
    },
    "Course": {
      "title": "Course",
      "description": "Course lesson or module",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "system": { "type": "string", "enum": ["7Edu", "TOTVS"] },
        "duration": { "type": "string" },
        "difficulty": { "type": "string" },
        "thumbnail": { "type": "string" },
        "videoUrl": { "type": "string" },
        "pdfUrl": { "type": "string" }
      },
      "required": ["id", "title", "system", "videoUrl"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Collection of system users"
    },
    "courses/{courseId}": {
      "schema": "Course",
      "description": "Collection of available courses"
    }
  }
}
